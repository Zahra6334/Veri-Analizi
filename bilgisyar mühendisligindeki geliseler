l()\n    model.config.forced_decoder_ids = processor.get_decoder_prompt_ids(language=LANGUAGE, task=TASK)\n    results = []\n    for i in range(0, len(utts), BATCH_SIZE):\n        batch  = utts[i:i+BATCH_SIZE]\n        audios = [load_audio(DATA / u[\"audio_path\"]) for u in batch]\n        inp    = processor.feature_extractor(\n            audios, sampling_rate=SAMPLE_RATE, return_tensors=\"pt\", padding=True\n        ).input_features.to(device, dtype=dtype)\n        with torch.no_grad():\n            ids = model.generate(inp, num_beams=BEAM, max_new_tokens=256,\n                                 language=LANGUAGE, task=TASK)\n        texts = processor.tokenizer.batch_decode(ids, skip_special_tokens=True)\n        for u, t in zip(batch, texts):\n            results.append({\"utterance_id\": u[\"utterance_id\"],\n                            \"orthographic_text\": _norm(t)})\n        if i % (BATCH_SIZE * 50) == 0:\n            log.info(f\"{min(i+BATCH_SIZE, len(utts))}/{len(utts)}\")\n    with open(OUT_FILE, \"w\") as f:\n        for r in results:\n            f.write(json.dumps(r, ensure_ascii=False) + \"\\\\n\")\n    log.info(\"Bitti!\")\n\nif __name__ == \"__main__\":\n    main()\n\"\"\"\nwith open(\"/kaggle/working/main.py\",\"w\") as f:\n    f.write(main_src)\nprint(\"✅ main.py hazır\")\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import zipfile\nfrom pathlib import Path\nfrom IPython.display import FileLink, display\n\nzip_path  = \"/kaggle/working/submission.zip\"\nmodel_dir = Path(\"/kaggle/working/best_child_model\")\nmain_py   = \"/kaggle/working/main.py\"\n\nwith zipfile.ZipFile(zip_path,\"w\",zipfile.ZIP_DEFLATED,compresslevel=1) as zf:\n    zf.write(main_py, \"main.py\")\n    for fp in model_dir.rglob(\"*\"):\n        if fp.is_file():\n            zf.write(fp, Path(\"best_child_model\") / fp.relative_to(model_dir))\n\nmb = Path(zip_path).stat().st_size / 1e6\nprint(f\"✅ submission.zip hazır ({mb:.0f} MB)