ent\n    def __len__(self): return len(self.df)\n    def __getitem__(self, idx):\n        row = self.df.iloc[idx]\n        try: speech, _ = librosa.load(row[\"audio_abs_path\"], sr=SAMPLE_RATE, mono=True)\n        except: speech = np.zeros(SAMPLE_RATE, dtype=np.float32)\n        if self.augment:\n            if random.random() < 0.25:\n                speech = librosa.effects.pitch_shift(speech, sr=SAMPLE_RATE, n_steps=random.uniform(-2,2))\n            if random.random() < 0.25:\n                speech = librosa.effects.time_stretch(speech, rate=random.uniform(0.9,1.1))\n                speech = speech[:int(MAX_DURATION*SAMPLE_RATE)]\n        feats  = self.processor.feature_extractor(speech, sampling_rate=SAMPLE_RATE).input_features[0]\n        labels = self.processor.tokenizer(row[\"normalized_text\"].strip()).input_ids\n        return {\"input_features\": feats, \"labels\": labels}\n\n@dataclass\nclass DataCollator:\n    processor: Any\n    def __call__(self, features):\n        inp   = [{\"input_features\": f[\"input_features\"]} for f in features]\n        batch = self.processor.feature_extractor.pad(inp, return_tensors=\"pt\")\n        lbl   = [{\"input_ids\": f[\"labels\"]} for f in features]\n        lb    = self.processor.tokenizer.pad(lbl, return_tensors=\"pt\")\n        labels = lb[\"input_ids\"].masked_fill(lb.attention_mask.ne(1), -100)\n        if (labels[:,0] == self.processor.tokenizer.bos_token_id).all():\n            labels = labels[:,1:]\n        batch[\"labels\"] = labels\n        return batch\n\n# ── ADIM 5: Model yükle ──\nprint(f\"\\n📥 {MODEL_NAME} yükleniyor (1-2 dk)...\")\nprocessor = WhisperProcessor.from_pretrained(MODEL_NAME, language=LANGUAGE, task=TASK)\nmodel = WhisperForConditionalGeneration.from_pretrained(\n    MODEL_NAME, torch_dtype=torch.float32, device_map=\"auto\")\nmodel.config.forced_decoder_ids = None\nmodel.config.suppress_tokens    = []\nmodel.config.use_cache          = False\nfor p in model.model.encoder.parameters():\n 