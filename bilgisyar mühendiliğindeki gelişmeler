red):\n    pid = pred.predictions; lid = pred.label_ids\n    lid[lid == -100] = processor.tokenizer.pad_token_id\n    ps = [normalizer(s) for s in processor.tokenizer.batch_decode(pid, skip_special_tokens=True)]\n    ls = [normalizer(s) for s in processor.tokenizer.batch_decode(lid, skip_special_tokens=True)]\n    return {\"wer\": round(wer_metric.compute(predictions=ps, references=ls), 4)}\n\nfrom transformers import Seq2SeqTrainer, Seq2SeqTrainingArguments\n\ntrain_ds = ChildrenSpeechDataset(df_train, processor)\nval_ds   = ChildrenSpeechDataset(df_val,   processor)\ncollator = DataCollator(processor=processor)\n\nargs = Seq2SeqTrainingArguments(\n    output_dir=\"/kaggle/working/whisper-children\",\n    per_device_train_batch_size=4,\n    gradient_accumulation_steps=8,\n    learning_rate=1e-4,   # LoRA için daha yüksek LR\n    warmup_steps=100,\n    max_steps=1000,\n    fp16=True,\n    eval_strategy=\"steps\",\n    eval_steps=200,\n    save_steps=200,\n    predict_with_generate=True,\n    generation_max_length=225,\n    load_best_model_at_end=True,\n    metric_for_best_model=\"wer\",\n    greater_is_better=False,\n    report_to=\"none\",\n    save_total_limit=2,\n)\ntrainer = Seq2SeqTrainer(\n    args=args, model=model,\n    train_dataset=train_ds, eval_dataset=val_ds,\n    data_collator=collator, compute_metrics=compute_metrics,\n)\n\nprint(\"🚀 EĞİTİM BAŞLIYOR...\")\ntrainer.train()\n\n# ← EN KRİTİK KISIM: modeli kaydet\nFINAL_MODEL = \"/kaggle/working/best_child_model\"\nmodel.save_pretrained(FINAL_MODEL)\nprocessor.save_pretrained(FINAL_MODEL)\nprint(f\"✅ Model kaydedildi → {FINAL_MODEL}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"main_src = \"\"\"\\\nimport os, json, logging\nimport torch, librosa, numpy as np\nfrom pathlib import Path\n\nlogging.basicConfig(level=logging.INFO, format=\"%(asctime)s %(message)s\")\nlog = logging.getLogger(__name__)\n\nBASE        = Path(\"/code_execution\")\nDATA        = 