p    = processor.feature_extractor(\n            audios, sampling_rate=SAMPLE_RATE, return_tensors=\"pt\", padding=True\n        ).input_features.to(device, dtype=dtype)\n        \n        with torch.no_grad():\n            ids = model.generate(inp, max_new_tokens=256, language=LANGUAGE, task=TASK)\n            \n        texts = processor.tokenizer.batch_decode(ids, skip_special_tokens=True)\n        for u, t in zip(batch, texts):\n            results.append({\"utterance_id\": u[\"utterance_id\"],\n                            \"orthographic_text\": _norm(t)})\n        \n        if i % 100 == 0:\n            log.info(f\"Ilerleme: {i}/{len(utts)}\")\n\n    with open(OUT_FILE, \"w\") as f:\n        for r in results:\n            f.write(json.dumps(r, ensure_ascii=False) + \"\\\\n\")\n    log.info(\"Islem tamamlandi!\")\n\nif __name__ == \"__main__\":\n    main()\n\"\"\"\n\nwith open(\"/kaggle/working/main.py\", \"w\", encoding=\"utf-8\") as f:\n    f.write(main_src)\n\nprint(\"✅ main.py başarıyla oluşturuldu. Şimdi zip hücresini tekrar çalıştırabilirsin.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Bu hücreyi şimdi çalıştırabilirsin, main.py artık orada!\nimport zipfile\nfrom pathlib import Path\n\nzip_path = \"/kaggle/working/submission.zip\"\nmodel_dir = Path(\"/kaggle/working/best_child_model\") # FINAL_MODEL değişkeni\n\nwith zipfile.ZipFile(zip_path, \"w\", zipfile.ZIP_DEFLATED) as zf:\n    zf.write(\"/kaggle/working/main.py\", \"main.py\")\n    for fp in model_dir.rglob(\"*\"):\n        if fp.is_file():\n            zf.write(fp, Path(\"best_child_model\") / fp.relative_to(model_dir))\n\nprint(f\"✅ {zip_path} başarıyla oluşturuldu!\")","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}